[Unit]
Description=Bardcastle Firewall dashboard HTTP-to-HTTPS redirect
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=bardcastle-web
Group=bardcastle-web
AmbientCapabilities=CAP_NET_BIND_SERVICE
WorkingDirectory=/opt/bardcastle-firewall/webui/backend
ExecStart=/opt/bardcastle-webui/venv/bin/uvicorn redirect:app --host 0.0.0.0 --port 80
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
