# WireGuard client configuration
# Generated by bardcastle-firewall
# Give this file to the client. Do NOT store it on the server after deployment.

[Interface]
# Client's private key (unique per device, keep secret!)
PrivateKey = {{ client_private_key }}

# VPN address assigned to this client. The IPv6 address is required for the
# ::/0 route below to actually carry traffic; without it IPv6 is blackholed.
Address = {{ client_ip }}/24{% if client_ip6 %}, {{ client_ip6 }}/64{% endif %}

# Use the router's LAN IP as the DNS server so the client can resolve
# internal hostnames while connected to the VPN.
DNS = {{ dns_server }}

# Tunnel MTU. Deliberately conservative: a device that roams onto a path with a
# smaller MTU (hotel wifi, mobile hotspot, PPPoE) has its oversized packets
# dropped upstream, and the ICMP reply that would trigger path MTU discovery is
# usually filtered. The result is a silent blackhole where DNS and connection
# setup work but TLS handshakes and transfers stall, which reads as "connected
# but nothing works". 1280 is the IPv6 minimum every network must carry, so it
# keeps working wherever the device goes.
MTU = {{ client_mtu | default(1280) }}

[Peer]
# Server's public key
PublicKey = {{ server_public_key }}

# Server endpoint — the router's public IP or hostname and WireGuard port
Endpoint = {{ endpoint }}:{{ vpn_port }}

# Route ALL traffic through the VPN (full tunnel mode).
# For split-tunnel, replace with specific subnets (e.g., 10.0.0.0/24).
AllowedIPs = 0.0.0.0/0, ::/0

# Send a keepalive packet every 25 seconds to maintain the connection
# through NATs and stateful firewalls.
PersistentKeepalive = 25
