# WireGuard client configuration
# Generated by bardcastle-firewall
# Give this file to the client — do NOT store it on the server after deployment.

[Interface]
# Client's private key (unique per device — keep secret!)
PrivateKey = {{ client_private_key }}

# VPN address assigned to this client
Address = {{ client_ip }}/24

# Use the router's LAN IP as the DNS server so the client can resolve
# internal hostnames while connected to the VPN.
DNS = {{ dns_server }}

[Peer]
# Server's public key
PublicKey = {{ server_public_key }}

# Server endpoint — the router's public IP or hostname and WireGuard port
Endpoint = {{ endpoint }}:{{ vpn_port }}

# Route ALL traffic through the VPN (full tunnel mode).
# For split-tunnel, replace with specific subnets (e.g., 10.0.0.0/24).
AllowedIPs = 0.0.0.0/0, ::/0

# Send a keepalive packet every 25 seconds to maintain the connection
# through NATs and stateful firewalls.
PersistentKeepalive = 25
