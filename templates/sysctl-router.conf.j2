# /etc/sysctl.d/99-bardcastle-router.conf
# Sysctl settings for IP forwarding and router hardening
# Managed by bardcastle-firewall — do not edit manually

# =============================================================================
# IP Forwarding
# =============================================================================

# Enable IPv4 forwarding (required for NAT/routing between interfaces)
net.ipv4.ip_forward = 1

# Enable IPv6 forwarding
net.ipv6.conf.all.forwarding = 1

# =============================================================================
# ICMP Hardening
# =============================================================================

# Do not accept ICMP redirects (prevent MITM attacks)
net.ipv4.conf.all.accept_redirects = 0
net.ipv4.conf.default.accept_redirects = 0
net.ipv6.conf.all.accept_redirects = 0
net.ipv6.conf.default.accept_redirects = 0

# Do not send ICMP redirects (we are a router, but we control our own routes)
net.ipv4.conf.all.send_redirects = 0
net.ipv4.conf.default.send_redirects = 0

# =============================================================================
# Source Routing
# =============================================================================

# Disable source routing (prevents attackers from specifying the route)
net.ipv4.conf.all.accept_source_route = 0
net.ipv4.conf.default.accept_source_route = 0
net.ipv6.conf.all.accept_source_route = 0
net.ipv6.conf.default.accept_source_route = 0

# =============================================================================
# SYN Flood Protection
# =============================================================================

# Enable TCP SYN cookies (protection against SYN flood attacks)
net.ipv4.tcp_syncookies = 1

# =============================================================================
# Reverse Path Filtering
# =============================================================================

# Enable strict reverse path filtering (drop packets with spoofed source IPs)
net.ipv4.conf.all.rp_filter = 1
net.ipv4.conf.default.rp_filter = 1

# =============================================================================
# Martian Logging
# =============================================================================

# Log packets with impossible source addresses (martians)
net.ipv4.conf.all.log_martians = 1
net.ipv4.conf.default.log_martians = 1

# =============================================================================
# IPv6 Autoconf — Disable on WAN
# =============================================================================

# Disable the *kernel's* IPv6 autoconfiguration on the WAN. This does not
# disable IPv6 on the WAN: systemd-networkd manages that interface and performs
# router-advertisement and DHCPv6 handling itself in userspace (it sets the
# kernel's accept_ra to 0 for exactly this reason), so the WAN still receives a
# global IPv6 address and default route from the ISP.
#
# Do not "fix" this by disabling IPv6 on the WAN. The VPN tunnel is dual stack
# and masquerades its ULA prefix out this interface (NAT66), so a WAN without a
# global IPv6 address silently breaks IPv6 for every VPN client.
net.ipv6.conf.{{ wan_interface }}.autoconf = 0
net.ipv6.conf.{{ wan_interface }}.accept_ra = 0
